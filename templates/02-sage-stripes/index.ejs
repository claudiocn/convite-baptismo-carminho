<%- include('../../core/html/head', { 
    title: data.title, 
    themeColor: data.themeColor, 
    description: data.description, 
    baseUrl: data.baseUrl, 
    cssFiles: ['style.css'] 
}) %>

<div class="invitation-card" id="main-card">
  <div class="inner-frame">
    
    <div class="top-ornament">
      <svg viewBox="0 0 100 150" xmlns="http://www.w3.org/2000/svg">
        <path d="M45,10 L45,45 L10,45 L10,55 L45,55 L45,140 L55,140 L55,55 L90,55 L90,45 L55,45 L55,10 Z" />
        <circle cx="50" cy="50" r="15" fill="none" stroke="currentColor" stroke-width="2"/>
      </svg>
    </div>

    <div class="intro-text">Please join us for the</div>
    <h1 class="event-type"><%= data.tipoEvento %></h1>
    <div class="intro-text">of our daughter</div>
    
    <h2 class="child-name"><%- data.nomeCrianca %></h2>

    <div class="date-time">
      <%- data.dataHora %>
    </div>

    <div class="locations">
      <% if(data.cerimonia) { %>
        <div class="location-block" onclick="toggleDetails('cerimonia-details', this)">
          <h4><%= data.cerimonia.nome %></h4>
          <div id="cerimonia-details" class="hidden-details">
            <p><%- data.cerimonia.morada %></p>
            <% if(data.cerimonia.linkMapa) { %>
              <a href="<%= data.cerimonia.linkMapa %>" target="_blank" class="map-btn">Ver no Mapa</a>
            <% } %>
          </div>
        </div>
      <% } %>

      <% if(data.rececao) { %>
        <div class="location-block" onclick="toggleDetails('rececao-details', this)">
          <div class="script-subtitle"><%= data.rececao.nome %></div>
          <div id="rececao-details" class="hidden-details">
            <p><%- data.rececao.morada %></p>
            <% if(data.rececao.linkMapa) { %>
              <a href="<%= data.rececao.linkMapa %>" target="_blank" class="map-btn">Ver no Mapa</a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="rsvp">
      <div>Please RSVP</div>
      <% if(data.contactos && data.contactos.length > 0) { %>
        <div class="rsvp-links">
          <% data.contactos.forEach(function(contacto) { %>
            <a href="<%= contacto.link %>"><%= contacto.nome %></a>
          <% }); %>
        </div>
      <% } %>
    </div>

  </div>
</div>

<%- include('../../core/html/foot') %>