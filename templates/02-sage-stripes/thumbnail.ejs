<%- include('../../core/html/head', { 
    title: data.title, 
    themeColor: data.themeColor, 
    description: data.description, 
    baseUrl: data.baseUrl, 
    cssFiles: ['style.css', 'thumbnail.css'] 
}) %>

<div class="invitation-thumbnail" id="main-card">
  <div class="inner-frame">
    
    <div class="left-col">
      <div class="top-ornament">
        <svg viewBox="0 0 100 150" xmlns="http://www.w3.org/2000/svg">
          <path d="M45,10 L45,45 L10,45 L10,55 L45,55 L45,140 L55,140 L55,55 L90,55 L90,45 L55,45 L55,10 Z" />
          <circle cx="50" cy="50" r="15" fill="none" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
    </div>

    <div class="right-col">
      <div class="intro-text">Please join us for the</div>
      <h1 class="event-type"><%= data.tipoEvento %></h1>
      
      <h2 class="child-name"><%- data.nomeCrianca.replace(/<br\s*\/?>/gi, ' ') %></h2>

      <div class="date-time">
        <%- data.dataHora.replace(/<br\s*\/?>/gi, ' | ') %>
      </div>
    </div>

  </div>
</div>

<%- include('../../core/html/foot') %>